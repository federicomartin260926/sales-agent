{% extends 'backend/layout.html.twig' %}

{% block content %}
  <section class="hero-panel">
    <div class="hero-copy">
      <div class="eyebrow-dark">Configuración operativa</div>
      <h2>LLM, audio y conectividad externa</h2>
      <p>
        La configuración editable vive en base de datos. Los valores sensibles se cifran y el runtime consume esta
        información como fuente de verdad, con `.env` reservado para bootstrap e infraestructura.
      </p>
    </div>
    <div class="hero-aside">
      <div class="badge-live">Operativo</div>
      <div class="hero-aside-title">Estado actual</div>
      <p>{{ overall_status_message }}</p>
    </div>
  </section>

  <section class="stats-grid">
    {% for metric in metrics %}
      {% include 'backend/configuration/_metric_card.html.twig' with { metric: metric } %}
    {% endfor %}
  </section>

  {{ feedback_html|raw }}

  <form method="post" action="/backend/configuration" class="tenant-form runtime-settings-form">
    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

    <section class="table-card">
      <div class="table-header">
        <div>
          <h3>LLM</h3>
          <p>Configuración de proveedores, modelos y endpoints usados por el scoring y la extracción con IA.</p>
        </div>
        <div style="display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end">
          <span class="{{ profile_badge_class }}">{{ profile_badge_label }}</span>
        </div>
      </div>
      {% include 'backend/configuration/_runtime_field.html.twig' with { field: profile } %}
    </section>

    <div class="config-columns">
      {% include 'backend/configuration/_runtime_section.html.twig' with { section: openai } %}
      {% include 'backend/configuration/_runtime_section.html.twig' with { section: local } %}
    </div>

    <div class="form-actions runtime-settings-actions form-actions-start">
      <button class="primary-action" type="submit" name="action" value="save">Guardar cambios</button>
    </div>
  </form>
{% endblock %}
