<section class="hero-panel hero-panel-single">
  <div class="hero-copy">
    <div class="eyebrow-dark">{{ dashboard_eyebrow }}</div>
    <h2>{{ dashboard_title }}</h2>
    <p>{{ dashboard_subtitle }}</p>
    <div class="hero-actions">
      {{ hero_actions_html|raw }}
    </div>
  </div>
</section>

{% if metric_cards_html is not empty %}
<section class="stats-grid">
  {{ metric_cards_html|raw }}
</section>
{% endif %}

<section class="cards-grid">
  {{ info_cards_html|raw }}
</section>
