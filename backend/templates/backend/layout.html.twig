{% extends 'base.html.twig' %}

{% block title %}{{ page_title }} - Sales Agent{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="/assets/backend.css">
{% endblock %}

{% block body %}
  <main class="layout">
    <aside class="sidebar">
      <div class="brand">
        <div class="brand-name">Sales Agent</div>
        <div class="brand-sub">Panel para definir negocios, productos/servicios y comportamiento del agente IA.</div>
      </div>
      <nav class="nav">
        {% if active_tenant is not null %}
            <div class="nav-section">
              <div class="nav-section-title">Negocio activo</div>
              <div class="nav-section-items">
                <a class="{{ active_nav == 'dashboard' ? 'active' : '' }}" href="/backend/dashboard">Dashboard</a>
                {% if can_manage_active_tenant|default(false) %}
                  <a class="{{ active_nav == 'tenant' ? 'active' : '' }} nav-tenant-link" href="{{ active_tenant.edit_url }}">Negocio</a>
                {% endif %}
                <a class="{{ active_nav == 'playbooks' ? 'active' : '' }}" href="/backend/playbooks">Guías comerciales</a>
                <a class="{{ active_nav == 'products' ? 'active' : '' }}" href="/backend/products">Productos / servicios</a>
                <a class="{{ active_nav == 'entry-points' ? 'active' : '' }}" href="/backend/entry-points">Puntos de entrada</a>
              </div>
          </div>

          {% if can_manage_active_tenant|default(false) or is_super_admin|default(false) %}
            <div class="nav-section">
              <div class="nav-section-title">Uso IA</div>
              <div class="nav-section-items">
                <a class="{{ active_nav == 'ai-usage' ? 'active' : '' }}" href="/backend/ai-usage">Uso IA</a>
              </div>
            </div>
          {% endif %}
        {% endif %}
        {% if is_super_admin|default(false) %}
          <div class="nav-section">
            <div class="nav-section-title">Administración técnica</div>
            <div class="nav-section-items">
              <a class="{{ active_nav == 'admin-external-tools' ? 'active' : '' }}" href="/backend/external-tools">Servidores MCP</a>
            </div>
          </div>

          <div class="nav-section">
            <div class="nav-section-title">Plataforma</div>
            <div class="nav-section-items">
              <a class="{{ active_nav == 'tenants' ? 'active' : '' }}" href="/backend/tenants">Negocios</a>
              <a class="{{ active_nav == 'admin-users' ? 'active' : '' }}" href="/backend/users">Usuarios</a>
              <a class="{{ active_nav == 'admin-configuration' ? 'active' : '' }}" href="/backend/configuration">Configuración</a>
              <a class="{{ active_nav in ['admin-api-health', 'api-health'] ? 'active' : '' }}" href="/backend/api-health">API Health</a>
            </div>
          </div>
        {% endif %}
      </nav>
    </aside>

    <section class="content-shell">
      <header class="topbar">
        <div>
          <h1 class="page-title">{{ page_title }}</h1>
          <div class="page-subtitle">{{ page_subtitle }}</div>
        </div>
        <div class="topbar-meta">
          {% if active_tenant is not null %}
            {% if is_super_admin|default(false) %}
              <a class="tenant-chip tenant-chip-active tenant-chip-linkable" href="/backend/tenants">
                <div class="tenant-chip-label">Negocio</div>
                <div class="tenant-chip-name-row">
                  <div class="tenant-chip-name">{{ active_tenant.name }}</div>
                  <span class="tenant-chip-link tenant-chip-link-icon" aria-hidden="true">↺</span>
                  <span class="visually-hidden">Cambiar negocio</span>
                </div>
              </a>
            {% elseif can_manage_active_tenant|default(false) %}
              <div class="tenant-chip tenant-chip-active">
                <div class="tenant-chip-label">Negocio</div>
                <div class="tenant-chip-name">{{ active_tenant.name }}</div>
                <div class="tenant-chip-link">Activo</div>
              </div>
            {% else %}
              <div class="tenant-chip tenant-chip-active">
                <div class="tenant-chip-label">Negocio</div>
                <div class="tenant-chip-name">{{ active_tenant.name }}</div>
              </div>
            {% endif %}
          {% elseif is_super_admin|default(false) %}
            <a class="tenant-chip tenant-chip-empty" href="/backend/tenants">
              <div class="tenant-chip-label">Negocio</div>
              <div class="tenant-chip-name">Sin negocio seleccionado</div>
              <span class="tenant-chip-link">Seleccionar negocio</span>
            </a>
          {% endif %}
          <div class="user-area">
          <details class="user-dropdown">
            <summary class="user-summary">
              <div class="user-chip">
                <div class="avatar">{{ current_user_initials|default('SA') }}</div>
                <div class="user-meta"><strong>{{ current_user_display_name|default('Usuario') }}</strong></div>
              </div>
              <span class="nav-caret">▾</span>
            </summary>
            <div class="user-links">
              <a href="/backend/profile">Mi perfil</a>
              <a href="/backend/logout">Salir</a>
            </div>
          </details>
          </div>
        </div>
      </header>

      <main class="main">
        {% block content %}{{ content|default('')|raw }}{% endblock %}
      </main>
    </section>
  </main>
  <script>
    (() => {
      const tabRoots = Array.from(document.querySelectorAll('[data-policy-tabs]'));
      if (tabRoots.length === 0) {
        return;
      }

      tabRoots.forEach((root) => {
        const tabs = Array.from(root.querySelectorAll('[data-policy-tab]'));
        const panels = Array.from(root.querySelectorAll('[data-policy-panel]'));

        if (tabs.length === 0 || panels.length === 0) {
          return;
        }

        const setActive = (key) => {
          tabs.forEach((tab) => {
            const isActive = tab.dataset.policyTab === key;
            tab.classList.toggle('active', isActive);
            tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
          });

          panels.forEach((panel) => {
            const isActive = panel.dataset.policyPanel === key;
            panel.classList.toggle('active', isActive);
            if (isActive) {
              panel.removeAttribute('hidden');
            } else {
              panel.setAttribute('hidden', '');
            }
          });
        };

        const initialTab = tabs.find((tab) => tab.classList.contains('active')) || tabs[0];
        setActive(initialTab.dataset.policyTab);

        tabs.forEach((tab) => {
          tab.addEventListener('click', () => setActive(tab.dataset.policyTab));
        });
      });
    })();
  </script>
{% endblock %}
