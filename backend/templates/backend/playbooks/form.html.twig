<section class="hero-panel">
  <div class="hero-copy">
    <div class="eyebrow-dark">Guías comerciales</div>
    <h2>{{ hero_title }}</h2>
    <p>{{ page_subtitle }}</p>
  </div>
  <div class="hero-aside">
    <div class="badge-live">Manager</div>
    <div class="hero-aside-title">Complemento</div>
    <p>Estas reglas complementan la política general del negocio y solo se aplican cuando necesitas ajustar un caso concreto.</p>
  </div>
</section>
<section class="table-card">
  <div class="table-header">
    <div>
      <h3>Ficha de la guía comercial</h3>
      <p>Define reglas específicas para un producto, campaña o situación comercial. Completa solo lo que cambie respecto a la política general del negocio.</p>
    </div>
    <div class="table-header-actions">
      <button
        class="secondary-action"
        type="button"
        title="Guía IA"
        data-bs-toggle="modal"
        data-bs-target="#playbook-draft-assistant-modal"
      >Guía IA</button>
    </div>
  </div>
  {{ error_html|raw }}
  <div class="form-alert form-alert-info">
    Esta guía es opcional. Si no hay una guía activa aplicable, el agente usará la configuración general del negocio.
  </div>
  <form method="post" action="{{ action_url }}" class="playbook-form">
    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
    <div class="form-grid">
      <div class="field">
        <label for="playbook-tenant">Negocio</label>
        <select id="playbook-tenant" name="tenantId" required>{{ tenant_options_html|raw }}</select>
        <div class="field-note">El negocio es obligatorio porque la guía complementa su política general.</div>
      </div>
      <div class="field">
        <label for="playbook-product">Producto / servicio</label>
        <select id="playbook-product" name="productId">{{ product_options_html|raw }}</select>
        <div class="field-note">Opcional: vincúlala a un producto, campaña o situación concreta si aplica.</div>
      </div>
      <div class="field field-full">
        <label for="playbook-name">Nombre de la guía comercial</label>
        <input id="playbook-name" name="name" type="text" value="{{ values.name }}" maxlength="255" required>
        <div class="field-note">Nombre visible para distinguir el override o complemento comercial.</div>
      </div>
      <div class="field field-check">
        <label for="playbook-active">Estado</label>
        <label class="checkbox-inline" for="playbook-active">
          <input id="playbook-active" name="isActive" type="checkbox" value="1"{% if values.isActive %} checked{% endif %}>
          <span>Guía activa</span>
        </label>
      </div>
      <div class="field field-full">
        <div class="section-label">Reglas específicas de esta guía</div>
        <div class="section-note">Estos campos complementan al negocio. Déjalos vacíos si la política general ya cubre este caso.</div>
        <div class="policy-tabs" data-policy-tabs>
          <div class="policy-tablist" role="tablist" aria-label="Reglas específicas de la guía">
            <button class="policy-tab active" type="button" role="tab" aria-selected="true" data-policy-tab="objective">Objetivo</button>
            <button class="policy-tab" type="button" role="tab" aria-selected="false" data-policy-tab="qualification">Cualificación</button>
            <button class="policy-tab" type="button" role="tab" aria-selected="false" data-policy-tab="scoring">Scoring</button>
            <button class="policy-tab" type="button" role="tab" aria-selected="false" data-policy-tab="agenda">Agenda</button>
            <button class="policy-tab" type="button" role="tab" aria-selected="false" data-policy-tab="handoff">Handoff</button>
            <button class="policy-tab" type="button" role="tab" aria-selected="false" data-policy-tab="actions">Acciones</button>
            <button class="policy-tab" type="button" role="tab" aria-selected="false" data-policy-tab="notes">Notas</button>
          </div>
          <div class="policy-panels">
            <div class="policy-panel active" role="tabpanel" data-policy-panel="objective">
              <label for="playbook-objective">Objetivo</label>
              <textarea id="playbook-objective" name="objective" rows="4" maxlength="2000" placeholder="Qué persigue la guía comercial.">{{ values.objective }}</textarea>
              <div class="field-note">Qué debe conseguir el agente en esta guía concreta. Si se deja vacío, usará el objetivo general del negocio.</div>
            </div>
            <div class="policy-panel" role="tabpanel" data-policy-panel="qualification" hidden>
              <label for="playbook-qualification-questions">Preguntas de cualificación</label>
              <textarea id="playbook-qualification-questions" name="qualificationQuestions" rows="4" maxlength="4000" placeholder="Una pregunta por línea.">{{ values.qualificationQuestions }}</textarea>
              <div class="field-note">Preguntas adicionales o específicas para este caso. No repitas las preguntas generales del negocio.</div>
            </div>
            <div class="policy-panel" role="tabpanel" data-policy-panel="scoring" hidden>
              <div class="form-grid">
                <div class="field">
                  <label for="playbook-max-score">Puntuación máxima</label>
                  <input id="playbook-max-score" name="maxScore" type="number" min="1" step="1" value="{{ values.maxScore }}">
                </div>
                <div class="field">
                  <label for="playbook-handoff-threshold">Umbral de handoff</label>
                  <input id="playbook-handoff-threshold" name="handoffThreshold" type="number" min="0" step="1" value="{{ values.handoffThreshold }}">
                </div>
                <div class="field">
                  <label for="playbook-positive-signals">Señales positivas</label>
                  <textarea id="playbook-positive-signals" name="positiveSignals" rows="4" maxlength="4000" placeholder="Una señal por línea.">{{ values.positiveSignals }}</textarea>
                </div>
                <div class="field">
                  <label for="playbook-negative-signals">Señales negativas</label>
                  <textarea id="playbook-negative-signals" name="negativeSignals" rows="4" maxlength="4000" placeholder="Una señal por línea.">{{ values.negativeSignals }}</textarea>
                </div>
              </div>
              <div class="field-note">Criterios específicos de prioridad para esta guía. Opcional.</div>
            </div>
            <div class="policy-panel" role="tabpanel" data-policy-panel="agenda" hidden>
              <label for="playbook-agenda-rules">Reglas de agenda</label>
              <textarea id="playbook-agenda-rules" name="agendaRules" rows="4" maxlength="4000" placeholder="Una regla por línea.">{{ values.agendaRules }}</textarea>
              <div class="field-note">Reglas especiales de agenda para este caso. Opcional.</div>
            </div>
            <div class="policy-panel" role="tabpanel" data-policy-panel="handoff" hidden>
              <label for="playbook-handoff-rules">Reglas de handoff</label>
              <textarea id="playbook-handoff-rules" name="handoffRules" rows="4" maxlength="4000" placeholder="Una regla por línea.">{{ values.handoffRules }}</textarea>
              <div class="field-note">Cuándo derivar a humano en esta guía si difiere de la política general.</div>
            </div>
            <div class="policy-panel" role="tabpanel" data-policy-panel="actions" hidden>
              <label for="playbook-allowed-actions">Acciones permitidas</label>
              <textarea id="playbook-allowed-actions" name="allowedActions" rows="4" maxlength="4000" placeholder="Una acción por línea.">{{ values.allowedActions }}</textarea>
              <div class="field-note">Acciones permitidas específicamente en esta guía. Opcional.</div>
            </div>
            <div class="policy-panel" role="tabpanel" data-policy-panel="notes" hidden>
              <label for="playbook-notes">Notas</label>
              <textarea id="playbook-notes" name="notes" rows="4" maxlength="4000" placeholder="Aclaraciones adicionales.">{{ values.notes }}</textarea>
              <div class="field-note">Notas adicionales que complementan la política general.</div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="form-actions">
      <button class="primary-action" type="submit">{{ submit_label }}</button>
    </div>
  </form>
</section>

<div
  class="modal fade tenant-draft-assistant-modal"
  id="playbook-draft-assistant-modal"
  tabindex="-1"
  aria-labelledby="playbook-draft-assistant-title"
  aria-hidden="true"
  data-playbook-draft-assistant
  data-endpoint="{{ playbook_ai_assistant_endpoint }}"
  data-csrf-token="{{ playbook_ai_assistant_token }}"
  data-initial-message="{{ playbook_ai_assistant_initial_message }}"
>
  <div class="modal-dialog modal-lg modal-dialog-centered tenant-draft-assistant-dialog">
    <div class="modal-content tenant-draft-assistant-shell">
      <div class="modal-header">
        <div>
          <h5 class="modal-title" id="playbook-draft-assistant-title">Guía IA</h5>
          <div class="tenant-draft-assistant-note">La guía rellena esta estrategia específica. Revisa y guarda manualmente.</div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
      </div>
      <div class="modal-body">
        <div class="tenant-draft-assistant-summary">
          <strong>Modo borrador</strong>
          <p>Responde en lenguaje natural. La IA hará preguntas breves sobre este caso concreto y te devolverá una propuesta para completar la guía comercial.</p>
        </div>
        <div class="tenant-draft-assistant-chat" data-chat-log aria-live="polite" aria-label="Conversación de guía IA"></div>
        <div class="tenant-draft-assistant-status" data-chat-status hidden></div>
        <div class="tenant-draft-assistant-auto-note" data-auto-apply-note hidden></div>
      </div>
      <div class="modal-footer tenant-draft-assistant-footer">
        <form class="tenant-draft-assistant-form" data-chat-form>
          <label class="visually-hidden" for="playbook-draft-assistant-input">Mensaje</label>
          <div class="tenant-draft-assistant-composer">
            <textarea
              id="playbook-draft-assistant-input"
              class="tenant-draft-assistant-input"
              rows="2"
              placeholder="Escribe aquí lo que sabes de esta guía..."
              data-chat-input
            ></textarea>
            <div class="tenant-draft-assistant-actions">
              <button type="button" class="secondary-action" data-send-button>Enviar</button>
            </div>
          </div>
          <div class="tenant-draft-assistant-compose-note">La guía se rellena en pantalla. No se guardará hasta que pulses Crear guía comercial.</div>
        </form>
      </div>
    </div>
  </div>
</div>

<script src="/assets/playbook-draft-assistant.js" defer></script>
