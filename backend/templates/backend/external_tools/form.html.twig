{% extends 'backend/layout.html.twig' %}

{% block content %}
  <section class="hero-panel">
    <div class="hero-copy">
      <div class="eyebrow-dark">Servidores MCP</div>
      <h2>{{ hero_title }}</h2>
      <p>
        Configura el servidor MCP remoto que OpenAI Responses API podrá usar como tool nativa para este tenant.
        En Docker local, la URL pública visible desde el navegador puede diferir de la que resuelve el contenedor.
      </p>
    </div>
    <div class="hero-aside">
      <div class="badge-live">Admin</div>
      <div class="hero-aside-title">Seguridad</div>
      <p>La autorización downstream se guarda cifrada. Si ya existe, el formulario la oculta y puedes dejarla vacía para conservarla.</p>
    </div>
  </section>

  {% if errors is not empty %}
    <div class="alert alert-error">
      <strong>Revisa el formulario</strong>
      <ul>
        {% for error in errors %}
          <li>{{ error }}</li>
        {% endfor %}
      </ul>
    </div>
  {% endif %}

  <section class="table-card">
    <div class="table-header">
      <div>
        <h3>Ficha de la herramienta</h3>
        <p>Una sola herramienta por tenant y tipo es suficiente para el contexto de contacto.</p>
      </div>
      <a class="secondary-action" href="/backend/external-tools">Volver al listado</a>
    </div>

    <form method="post" action="{{ action_url }}" class="tenant-form" data-external-tool-form>
      <input type="hidden" name="_csrf_token" value="{{ form_token }}">
      <ul class="nav nav-tabs mb-4" id="external-tool-form-tabs" role="tablist">
        <li class="nav-item" role="presentation">
          <button class="nav-link active" id="external-tool-ficha-tab" data-bs-toggle="tab" data-bs-target="#external-tool-ficha-panel" type="button" role="tab" aria-controls="external-tool-ficha-panel" aria-selected="true">Ficha</button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link" id="external-tool-connection-tab" data-bs-toggle="tab" data-bs-target="#external-tool-connection-panel" type="button" role="tab" aria-controls="external-tool-connection-panel" aria-selected="false">Conexión</button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link" id="external-tool-auth-tab" data-bs-toggle="tab" data-bs-target="#external-tool-auth-panel" type="button" role="tab" aria-controls="external-tool-auth-panel" aria-selected="false">Autorización</button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link" id="external-tool-runtime-tab" data-bs-toggle="tab" data-bs-target="#external-tool-runtime-panel" type="button" role="tab" aria-controls="external-tool-runtime-panel" aria-selected="false">MCP runtime</button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link" id="external-tool-advanced-tab" data-bs-toggle="tab" data-bs-target="#external-tool-advanced-panel" type="button" role="tab" aria-controls="external-tool-advanced-panel" aria-selected="false">Avanzado</button>
        </li>
      </ul>

      <div class="tab-content pt-4">
        <div class="tab-pane fade show active" id="external-tool-ficha-panel" role="tabpanel" aria-labelledby="external-tool-ficha-tab" tabindex="0">
          <div class="field field-full">
            <div class="section-label">Identidad de la herramienta</div>
            <div class="section-note">La ficha básica identifica el servidor o webhook por tenant y define su uso funcional.</div>
            <div class="form-grid">
              <div class="field">
                <label for="tool-tenant">Negocio</label>
                <input id="tool-tenant" type="text" value="{{ active_tenant_name ?: 'Sin negocio seleccionado' }}" readonly>
                <div class="field-note">La herramienta se guardará en el negocio activo.</div>
              </div>

              <div class="field">
                <label for="tool-name">Nombre</label>
                <input id="tool-name" name="name" type="text" value="{{ values.name }}" maxlength="255" required>
                <div class="field-note">Nombre visible para el equipo. Ejemplo: “MCP principal de Mary”.</div>
              </div>

              <div class="field">
                <label for="tool-type">Tipo</label>
                <select id="tool-type" name="type" required>
                  <option value="mcp_remote"{{ values.type == 'mcp_remote' ? ' selected' : '' }}>Servidor MCP remoto</option>
                  <option value="handoff_webhook"{{ values.type == 'handoff_webhook' ? ' selected' : '' }}>Webhook n8n de handoff</option>
                  <option value="contact_context"{{ values.type == 'contact_context' ? ' selected' : '' }}>Compatibilidad antigua</option>
                </select>
                <div class="field-note">`mcp_remote` es el servidor MCP remoto usado por OpenAI Responses API. `handoff_webhook` recibe eventos `sales_agent.handoff_requested`. `contact_context` se mantiene por compatibilidad antigua.</div>
              </div>

              <div class="field">
                <label for="tool-provider">Provider</label>
                <select id="tool-provider" name="provider" required>
                  <option value="n8n_webhook"{{ values.provider == 'n8n_webhook' ? ' selected' : '' }}>n8n_webhook</option>
                  <option value="openai_remote_mcp"{{ values.provider == 'openai_remote_mcp' ? ' selected' : '' }}>OpenAI Responses API</option>
                  <option value="mcp_remote"{{ values.provider == 'mcp_remote' ? ' selected' : '' }}>mcp_remote</option>
                </select>
                <div class="field-note">El provider define el proveedor técnico compatible. Para handoff webhook usa `n8n_webhook`. Para MCP remoto usa un provider MCP compatible.</div>
              </div>

              <div class="field field-check">
                <label for="tool-active">Estado / herramienta activa</label>
                <label class="checkbox-inline" for="tool-active">
                  <input id="tool-active" name="isActive" type="checkbox" value="1"{{ values.isActive ? ' checked' : '' }}>
                  <span>Herramienta activa</span>
                </label>
              </div>
            </div>
          </div>
        </div>

        <div class="tab-pane fade" id="external-tool-connection-panel" role="tabpanel" aria-labelledby="external-tool-connection-tab" tabindex="0">
          <div class="field field-full">
            <div class="section-label">Endpoint</div>
            <div class="section-note">Indica la URL pública que resolverá la herramienta según su tipo.</div>
            <div class="field">
              <label for="tool-webhook">Webhook URL</label>
              <input id="tool-webhook" name="webhookUrl" type="url" value="{{ values.webhookUrl }}" maxlength="2048" placeholder="http://host.docker.internal:5680/webhook/sales-agent/contact-context" required>
              <div class="field-note">Para `mcp_remote`: URL pública del servidor MCP remoto. En Docker local la URL visible desde navegador puede diferir de la que resuelve el contenedor.</div>
              <div class="field-note">Para `handoff_webhook`: endpoint n8n que recibirá eventos `sales_agent.handoff_requested`.</div>
              <div class="field-note">Para `contact_context`: compatibilidad antigua; usa la URL esperada por el flujo legado.</div>
            </div>
            <div class="field mt-4">
              <label for="tool-timeout">Timeout segundos</label>
              <input id="tool-timeout" name="timeoutSeconds" type="number" min="1" max="30" step="1" value="{{ values.timeoutSeconds }}" required>
              <div class="field-note">Tiempo máximo de espera para la llamada remota.</div>
            </div>
          </div>
        </div>

        <div class="tab-pane fade" id="external-tool-auth-panel" role="tabpanel" aria-labelledby="external-tool-auth-tab" tabindex="0">
          <div class="field field-full">
            <div class="section-label">Autorización hacia la herramienta</div>
            <div class="section-note">Aquí se separan la auth del webhook y la autorización downstream tenant-scoped.</div>
            <div class="form-grid">
              <div class="field">
                <label for="tool-auth">Auth type</label>
                <select id="tool-auth" name="authType" required>
                  <option value="none"{{ values.authType == 'none' ? ' selected' : '' }}>none</option>
                  <option value="bearer"{{ values.authType == 'bearer' ? ' selected' : '' }}>bearer</option>
                </select>
                <div class="field-note">Para `handoff_webhook` debe quedarse en `none`. En esta primera fase no se permite bearer token para handoff.</div>
              </div>

              <div class="field field-full">
                <label for="tool-token">Token CRM para n8n/MCP</label>
                <input id="tool-token" name="bearerToken" type="password" value="" autocomplete="new-password" placeholder="{{ has_token ? '•••••••• configurado — dejar vacío para conservar' : 'Pega el token Bearer o token puro' }}" data-default-placeholder="{{ has_token ? '•••••••• configurado — dejar vacío para conservar' : 'Pega el token Bearer o token puro' }}">
                <div class="field-note">Autorización downstream tenant-scoped que Sales Agent enviará como <code>Authorization</code> al servidor MCP cuando corresponda.</div>
                <div class="field-note">No se envía al prompt, ni como argumento de tool, ni en payloads JSON. No se usa como credencial de <code>handoff_webhook</code>.</div>
                <div class="field-note">El valor no se repuebla en el input por seguridad; si el estado dice “Configurado”, el token sigue guardado.</div>
                <div class="field-note">Estado: {{ downstream_authorization_configured ? 'Configurado' : 'No configurado' }}</div>
                {% if is_edit and has_token %}
                  <label class="checkbox-inline mt-2" for="tool-token-clear">
                    <input id="tool-token-clear" name="clearBearerToken" type="checkbox" value="1">
                    <span>Eliminar token guardado</span>
                  </label>
                  <div class="field-note">Activa esta opción para borrar el token guardado en lugar de conservarlo.</div>
                {% endif %}
              </div>
            </div>
          </div>
        </div>

        <div class="tab-pane fade" id="external-tool-runtime-panel" role="tabpanel" aria-labelledby="external-tool-runtime-tab" tabindex="0">
          <div class="field field-full">
            <div class="section-label">MCP runtime</div>
            <div class="section-note">Bloque operativo para servidores MCP remotos. Si el tipo no es `mcp_remote`, estos campos quedan como metadatos de compatibilidad.</div>
            <div class="form-grid">
              <div class="field">
                <label for="tool-server-label">Server label MCP</label>
                <input id="tool-server-label" name="serverLabel" type="text" value="{{ values.serverLabel }}" maxlength="120" placeholder="tenant_main_mcp">
                <div class="field-note">Identifica el servidor remoto en OpenAI Responses API.</div>
              </div>

              <div class="field field-full">
                <label for="tool-allowed-tools">Allowed tools MCP</label>
                <textarea id="tool-allowed-tools" name="allowedTools" rows="3" spellcheck="false" placeholder="search_properties&#10;appointment_availability">{{ values.allowedTools }}</textarea>
                <div class="field-note">Una herramienta por línea o separadas por coma.</div>
              </div>

              <div class="field">
                <label for="tool-approval">Require approval</label>
                <select id="tool-approval" name="requireApproval">
                  <option value="auto"{{ values.requireApproval == 'auto' ? ' selected' : '' }}>auto (legacy)</option>
                  <option value="never"{{ values.requireApproval == 'never' ? ' selected' : '' }}>never</option>
                  <option value="always"{{ values.requireApproval == 'always' ? ' selected' : '' }}>always</option>
                </select>
                <div class="field-note">Para MCP remoto, `auto` se interpreta como `never` en el runtime.</div>
              </div>

              <div class="field field-check">
                <label for="tool-llm-enabled">LLM enabled</label>
                <label class="checkbox-inline" for="tool-llm-enabled">
                  <input id="tool-llm-enabled" name="enabledForLlm" type="checkbox" value="1"{{ values.enabledForLlm ? ' checked' : '' }}>
                  <span>Disponible para el LLM</span>
                </label>
              </div>

              <div class="field field-check">
                <label for="tool-runtime-default">Runtime</label>
                <label class="checkbox-inline" for="tool-runtime-default">
                  <input id="tool-runtime-default" name="isRuntimeDefault" type="checkbox" value="1"{{ values.isRuntimeDefault ? ' checked' : '' }}{{ values.isActive ? '' : ' disabled' }}>
                  <span>Usar como MCP principal de runtime</span>
                </label>
                <div class="field-note">Solo los servidores activos pueden ser principales. Si marcas uno, los demás MCP activos del negocio dejarán de ser el principal.</div>
              </div>
            </div>
          </div>
        </div>

        <div class="tab-pane fade" id="external-tool-advanced-panel" role="tabpanel" aria-labelledby="external-tool-advanced-tab" tabindex="0">
          <div class="field field-full">
            <div class="section-label">Avanzado</div>
            <div class="section-note">Configuración interna y notas operativas del servidor o webhook.</div>
            <div class="form-grid">
              <div class="field field-full">
                <label for="tool-notes">Notas MCP</label>
                <textarea id="tool-notes" name="notes" rows="3" placeholder="Observaciones internas, scopes, comportamiento esperado">{{ values.notes }}</textarea>
                <div class="field-note">Observaciones internas, scopes o comportamiento esperado.</div>
              </div>

              <div class="field field-full">
                <label for="tool-config">Config JSON</label>
                <textarea id="tool-config" name="config" rows="8" spellcheck="false" placeholder="{}">{{ values.config }}</textarea>
                <div class="field-note">Si lo dejas vacío se guardará como <code>{}</code>. Debe ser JSON válido.</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="form-actions">
        <button class="primary-action" type="submit">{{ submit_label }}</button>
      </div>
    </form>
  </section>

  <script>
    (() => {
      const form = document.querySelector('[data-external-tool-form]');
      if (!form) {
        return;
      }

      const typeSelect = form.querySelector('#tool-type');
      const authSelect = form.querySelector('#tool-auth');
      const tokenInput = form.querySelector('#tool-token');
      const defaultPlaceholder = tokenInput.getAttribute('data-default-placeholder') || tokenInput.placeholder;

      if (!typeSelect || !authSelect || !tokenInput) {
        return;
      }

      const syncAuthState = () => {
        const isHandoffWebhook = typeSelect.value === 'handoff_webhook';
        authSelect.disabled = isHandoffWebhook;
        tokenInput.disabled = isHandoffWebhook;

        if (isHandoffWebhook) {
          authSelect.value = 'none';
          tokenInput.value = '';
          tokenInput.placeholder = 'No disponible para handoff_webhook';
        } else {
          tokenInput.placeholder = defaultPlaceholder;
        }
      };

      typeSelect.addEventListener('change', syncAuthState);
      syncAuthState();
    })();
  </script>
{% endblock %}
