{% extends 'backend/layout.html.twig' %}

{% block content %}
  <section class="hero-panel">
    <div class="hero-copy">
      <div class="eyebrow-dark">Servidores MCP</div>
      <h2>{{ hero_title }}</h2>
      <p>
        Configura el servidor MCP remoto que OpenAI Responses API podrá usar como tool nativa para este tenant.
        En Docker local, la URL pública visible desde el navegador puede diferir de la que resuelve el contenedor.
      </p>
    </div>
    <div class="hero-aside">
      <div class="badge-live">Admin</div>
      <div class="hero-aside-title">Seguridad</div>
      <p>La autorización downstream se guarda cifrada. Si ya existe, el formulario la oculta y puedes dejarla vacía para conservarla.</p>
    </div>
  </section>

  {% if errors is not empty %}
    <div class="alert alert-error">
      <strong>Revisa el formulario</strong>
      <ul>
        {% for error in errors %}
          <li>{{ error }}</li>
        {% endfor %}
      </ul>
    </div>
  {% endif %}

  <section class="table-card">
    <div class="table-header">
      <div>
        <h3>Ficha de la herramienta</h3>
        <p>Una sola herramienta por tenant y tipo es suficiente para el contexto de contacto.</p>
      </div>
      <a class="secondary-action" href="/backend/external-tools">Volver al listado</a>
    </div>

    <form method="post" action="{{ action_url }}" class="tenant-form">
      <input type="hidden" name="_csrf_token" value="{{ form_token }}">
      <div class="form-grid">
        <div class="field field-full">
          <label for="tool-tenant">Negocio</label>
          <input id="tool-tenant" type="text" value="{{ active_tenant_name ?: 'Sin negocio seleccionado' }}" readonly>
          <div class="field-note">El servidor MCP se guardará en el negocio activo.</div>
        </div>

        <div class="field">
          <label for="tool-name">Nombre</label>
          <input id="tool-name" name="name" type="text" value="{{ values.name }}" maxlength="255" required>
        </div>

        <div class="field">
          <label for="tool-type">Tipo</label>
          <select id="tool-type" name="type" required>
            <option value="mcp_remote"{{ values.type == 'mcp_remote' ? ' selected' : '' }}>mcp_remote</option>
            <option value="handoff_webhook"{{ values.type == 'handoff_webhook' ? ' selected' : '' }}>handoff_webhook</option>
            <option value="contact_context"{{ values.type == 'contact_context' ? ' selected' : '' }}>contact_context</option>
          </select>
          <div class="field-note">`handoff_webhook` sirve para derivaciones a n8n. `contact_context` se mantiene sólo por compatibilidad antigua.</div>
        </div>

        <div class="field">
          <label for="tool-provider">Provider</label>
          <select id="tool-provider" name="provider" required>
            <option value="n8n_webhook"{{ values.provider == 'n8n_webhook' ? ' selected' : '' }}>n8n_webhook</option>
            <option value="openai_remote_mcp"{{ values.provider == 'openai_remote_mcp' ? ' selected' : '' }}>openai_remote_mcp</option>
            <option value="mcp_remote"{{ values.provider == 'mcp_remote' ? ' selected' : '' }}>mcp_remote</option>
          </select>
          <div class="field-note">Para handoff webhook usa `n8n_webhook`. Para MCP remoto usa un provider MCP compatible.</div>
        </div>

        <div class="field field-full">
          <label for="tool-webhook">Webhook URL</label>
          <input id="tool-webhook" name="webhookUrl" type="url" value="{{ values.webhookUrl }}" maxlength="2048" placeholder="http://host.docker.internal:5680/webhook/sales-agent/contact-context" required>
          <div class="field-note">En MCP remoto apunta al servidor MCP. Para handoff webhook apunta al endpoint n8n. En Docker local puede necesitar <code>host.docker.internal</code>.</div>
        </div>

        <div class="field">
          <label for="tool-auth">Auth type</label>
          <select id="tool-auth" name="authType" required>
            <option value="none"{{ values.authType == 'none' ? ' selected' : '' }}>none</option>
            <option value="bearer"{{ values.authType == 'bearer' ? ' selected' : '' }}>bearer</option>
          </select>
          <div class="field-note">Para handoff webhook usa <code>none</code> en esta primera fase. El bearer se reserva para MCP/downstream.</div>
          <div class="field-note">Para autenticación downstream usa <code>Name=Authorization</code> y <code>Value=Bearer &lt;token&gt;</code>. Sales Agent guarda sólo el token, sin el prefijo Bearer.</div>
          <div class="field-note">Si pegas un token, el formulario lo tratará como <code>bearer</code> al guardar para que no se pierda.</div>
        </div>

        <div class="field field-full">
          <label for="tool-token">Token CRM para n8n/MCP</label>
          <input id="tool-token" name="bearerToken" type="password" value="" autocomplete="new-password" placeholder="{{ has_token ? '•••••••• configurado — dejar vacío para conservar' : 'Pega el token Bearer o token puro' }}">
          <div class="field-note">Autorización downstream opcional que Sales Agent enviará como <code>Authorization</code> al servidor MCP. No se envía al prompt ni como argumento de tool.</div>
          <div class="field-note">El valor no se repuebla en el input por seguridad; si el estado dice “Configurado”, el token sigue guardado.</div>
          <div class="field-note">Estado: {{ downstream_authorization_configured ? 'Configurado' : 'No configurado' }}</div>
          {% if is_edit and has_token %}
            <label class="checkbox-inline mt-2" for="tool-token-clear">
              <input id="tool-token-clear" name="clearBearerToken" type="checkbox" value="1">
              <span>Eliminar token guardado</span>
            </label>
            <div class="field-note">Activa esta opción para borrar el token guardado en lugar de conservarlo.</div>
          {% endif %}
        </div>

        <div class="field">
          <label for="tool-server-label">Server label MCP</label>
          <input id="tool-server-label" name="serverLabel" type="text" value="{{ values.serverLabel }}" maxlength="120" placeholder="tenant_main_mcp">
          <div class="field-note">Usado sólo para MCP remoto. Debe identificar el servidor remoto del tenant.</div>
        </div>

        <div class="field field-full">
          <label for="tool-allowed-tools">Allowed tools MCP</label>
          <textarea id="tool-allowed-tools" name="allowedTools" rows="3" spellcheck="false" placeholder="search_properties&#10;appointment_availability">{{ values.allowedTools }}</textarea>
          <div class="field-note">Opcional. Una herramienta por línea o separadas por coma.</div>
        </div>

        <div class="field">
          <label for="tool-approval">Require approval</label>
          <select id="tool-approval" name="requireApproval">
            <option value="auto"{{ values.requireApproval == 'auto' ? ' selected' : '' }}>auto (legacy)</option>
            <option value="never"{{ values.requireApproval == 'never' ? ' selected' : '' }}>never</option>
            <option value="always"{{ values.requireApproval == 'always' ? ' selected' : '' }}>always</option>
          </select>
          <div class="field-note">Para MCP remoto, auto se interpreta como never en el runtime.</div>
        </div>

        <div class="field field-check">
          <label for="tool-llm-enabled">LLM enabled</label>
          <label class="checkbox-inline" for="tool-llm-enabled">
            <input id="tool-llm-enabled" name="enabledForLlm" type="checkbox" value="1"{{ values.enabledForLlm ? ' checked' : '' }}>
            <span>Disponible para el LLM</span>
          </label>
        </div>

        <div class="field field-full">
          <label for="tool-notes">Notas MCP</label>
          <textarea id="tool-notes" name="notes" rows="3" placeholder="Observaciones internas, scopes, comportamiento esperado">{{ values.notes }}</textarea>
          <div class="field-note">Opcional. Útil para documentar el servidor MCP remoto de cada tenant.</div>
        </div>

        <div class="field">
          <label for="tool-timeout">Timeout segundos</label>
          <input id="tool-timeout" name="timeoutSeconds" type="number" min="1" max="30" step="1" value="{{ values.timeoutSeconds }}" required>
        </div>

        <div class="field field-check">
          <label for="tool-active">Estado</label>
          <label class="checkbox-inline" for="tool-active">
            <input id="tool-active" name="isActive" type="checkbox" value="1"{{ values.isActive ? ' checked' : '' }}>
            <span>Herramienta activa</span>
          </label>
        </div>

        <div class="field field-check">
          <label for="tool-runtime-default">Runtime</label>
          <label class="checkbox-inline" for="tool-runtime-default">
            <input id="tool-runtime-default" name="isRuntimeDefault" type="checkbox" value="1"{{ values.isRuntimeDefault ? ' checked' : '' }}{{ values.isActive ? '' : ' disabled' }}>
            <span>Usar como MCP principal de runtime</span>
          </label>
          <div class="field-note">Solo los servidores activos pueden ser principales. Si marcas uno, los demás MCP activos del negocio dejarán de ser el principal.</div>
        </div>

        <div class="field field-full">
          <label for="tool-config">Config JSON</label>
          <textarea id="tool-config" name="config" rows="8" spellcheck="false" placeholder="{}">{{ values.config }}</textarea>
          <div class="field-note">Si lo dejas vacío se guardará como <code>{}</code>. Debe ser JSON válido.</div>
        </div>
      </div>

      <div class="form-actions">
        <button class="primary-action" type="submit">{{ submit_label }}</button>
      </div>
    </form>
  </section>
{% endblock %}
