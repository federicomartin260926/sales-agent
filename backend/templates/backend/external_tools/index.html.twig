{% extends 'backend/layout.html.twig' %}

{% block content %}
  {% if tenant_required_html is defined and tenant_required_html is not null %}
    {{ tenant_required_html|raw }}
  {% else %}
  <section class="hero-panel">
    <div class="hero-copy">
      <div class="eyebrow-dark">Servidores MCP</div>
      <h2>Servidores MCP de {{ active_tenant_name }}</h2>
      <p>
        Configura para el negocio activo el servidor MCP remoto que OpenAI Responses API puede usar como tool nativa.
        En local con Docker, la URL pública visible desde el navegador puede diferir de la que resuelve el contenedor.
      </p>
    </div>
    <div class="hero-aside">
      <div class="badge-live">Admin</div>
      <div class="hero-aside-title">Prueba MCP</div>
      <p>El botón ▶ ejecuta una prueba real del servidor MCP seleccionado usando el runtime de sales-agent.</p>
      <a class="primary-action" href="/backend/external-tools/new">Crear servidor MCP</a>
    </div>
  </section>

  {% for message in app.flashes('success') %}
    <div class="alert alert-success">{{ message }}</div>
  {% endfor %}

  {% for message in app.flashes('error') %}
    <div class="alert alert-error">{{ message }}</div>
  {% endfor %}

  {% if runtime_state is defined and runtime_state is not null %}
    <div class="alert alert-warning">
      <strong>{{ runtime_state.value }}</strong>
      <div>{{ runtime_state.detail }}</div>
    </div>
  {% endif %}

  {% if filter_error is defined and filter_error is not null %}
    <div class="alert alert-error">{{ filter_error }}</div>
  {% endif %}

  {% if test_result is defined and test_result is not null %}
    <div class="alert {{ test_result.ok ? 'alert-success' : 'alert-warning' }}">
      <strong>Resultado de prueba</strong>
      <div class="subtle">ok: {{ test_result.ok ? 'true' : 'false' }} | found: {{ test_result.found ? 'true' : 'false' }} | provider: {{ test_result.provider|default('') }} | model: {{ test_result.model|default('') }}</div>
      <div class="subtle">status_code: {{ test_result.status_code is not null ? test_result.status_code : 'null' }} | latency_ms: {{ test_result.latency_ms|default(0) }} | error_code: {{ test_result.error_code|default('null') }}</div>
      <div>{{ test_result.summary|default('') }}</div>
      {% if test_result.reply is defined and test_result.reply|default('') != '' %}
        <div class="subtle">reply: {{ test_result.reply }}</div>
      {% endif %}
      {% if test_result.mcp_response_id is defined and test_result.mcp_response_id|default('') != '' %}
        <div class="subtle">mcp_response_id: {{ test_result.mcp_response_id }}</div>
      {% endif %}
      {% if test_result.mcp_errors is defined and test_result.mcp_errors is not empty %}
        <div class="subtle">mcp_errors: {{ test_result.mcp_errors|join(' | ') }}</div>
      {% endif %}
      {% if test_result.mcp_tool_traces is defined and test_result.mcp_tool_traces is not empty %}
        <div class="subtle">mcp_tool_traces:</div>
        <ul class="mb-0">
          {% for trace in test_result.mcp_tool_traces %}
            <li>
              {{ trace.type|default('') }}
              {% if trace.tool_name is defined and trace.tool_name|default('') != '' %} | {{ trace.tool_name }}{% endif %}
              {% if trace.status is defined and trace.status|default('') != '' %} | {{ trace.status }}{% endif %}
              {% if trace.output is defined and trace.output is not same as(null) %} | {{ trace.output|json_encode(constant('JSON_UNESCAPED_UNICODE')) }}{% endif %}
            </li>
          {% endfor %}
        </ul>
      {% endif %}
    </div>
  {% endif %}

  <section class="table-card">
    <div class="table-header">
      <div>
        <h3>Servidores MCP de {{ active_tenant_name }}</h3>
        <p>Se listan los servidores remotos activos e inactivos del negocio activo.</p>
      </div>
      <a class="primary-action" href="/backend/external-tools/new">Nuevo servidor MCP</a>
    </div>
    <div class="table-responsive">
      <table>
        <thead>
          <tr>
            <th>Tenant</th>
            <th>Herramienta</th>
            <th>Tipo / proveedor</th>
            <th>Webhook</th>
            <th>Auth</th>
            <th>Timeout</th>
            <th>Principal</th>
            <th>Estado</th>
            <th class="text-right">Acciones</th>
          </tr>
        </thead>
        <tbody>
          {% for tool in tools %}
            <tr>
              <td>
                <strong>{{ tool.tenantName }}</strong>
                <div class="subtle">{{ tool.tenantId }}</div>
              </td>
              <td>
                <strong>{{ tool.name }}</strong>
                <div class="subtle">Config: {{ tool.configSummary }}</div>
              </td>
              <td>
                <div>{{ tool.type }}</div>
                <div class="subtle">{{ tool.provider }}</div>
              </td>
              <td><code>{{ tool.webhookUrl ?: '—' }}</code></td>
              <td>
                <div>{{ tool.authType }}</div>
                {% if tool.hasBearerToken %}
                  <div class="subtle">Autorización downstream: configurada</div>
                {% else %}
                  <div class="subtle">Autorización downstream: no configurada</div>
                {% endif %}
              </td>
              <td>{{ tool.timeoutSeconds }}s</td>
              <td>
                {% if tool.isRuntimeDefault %}
                  <span class="status-ok">Principal</span>
                {% elseif tool.isActive %}
                  <form method="post" action="/backend/external-tools/{{ tool.id }}/mark-default" style="display:inline-flex;">
                    <input type="hidden" name="_csrf_token" value="{{ tool.runtimeDefaultToken }}">
                    <button class="secondary-action" type="submit">Marcar principal</button>
                  </form>
                {% else %}
                  <span class="status-off">No</span>
                {% endif %}
              </td>
              <td>{% if tool.isActive %}<span class="status-ok">Activo</span>{% else %}<span class="status-off">Inactivo</span>{% endif %}</td>
              <td class="text-right">
                <div class="tool-actions-inline">
                  <a class="icon-action tool-action-icon-button" href="/backend/external-tools/{{ tool.id }}/edit" title="Editar herramienta externa" aria-label="Editar herramienta externa">✎</a>
                  {% if tool.canTest %}
                    <form method="post" action="/backend/external-tools/{{ tool.id }}/test" style="display:inline-flex;">
                      <input type="hidden" name="_csrf_token" value="{{ tool.testToken }}">
                      <button class="icon-action tool-action-icon-button" type="submit" title="Probar MCP" aria-label="Probar MCP">▶</button>
                    </form>
                  {% else %}
                    <button class="icon-action tool-action-icon-button" type="button" title="Prueba MCP pendiente" aria-label="Prueba MCP pendiente" disabled>▶</button>
                  {% endif %}
                  <form method="post" action="/backend/external-tools/{{ tool.id }}/toggle" style="display:inline-flex;">
                    <input type="hidden" name="_csrf_token" value="{{ tool.toggleToken }}">
                    <button class="icon-action tool-action-icon-button" type="submit" title="{{ tool.isActive ? 'Desactivar' : 'Activar' }}" aria-label="{{ tool.isActive ? 'Desactivar' : 'Activar' }}">{{ tool.isActive ? '⏸' : '▶' }}</button>
                  </form>
                  {% if tool.isRuntimeDefault %}
                    <span class="badge-live">Runtime</span>
                  {% endif %}
                  <form method="post" action="/backend/external-tools/{{ tool.id }}/delete" onsubmit="return confirm('¿Eliminar esta herramienta externa?');" style="display:inline-flex;">
                    <input type="hidden" name="_csrf_token" value="{{ tool.deleteToken }}">
                    <button class="icon-action icon-action-danger tool-action-icon-button" type="submit" title="Eliminar herramienta externa" aria-label="Eliminar herramienta externa">🗑</button>
                  </form>
                </div>
              </td>
            </tr>
          {% else %}
            <tr>
              <td colspan="9" class="empty-row">No hay herramientas externas todavía.</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>
  {% endif %}
{% endblock %}
