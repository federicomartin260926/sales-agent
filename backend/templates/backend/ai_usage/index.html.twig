<section class="hero-panel">
  <div class="hero-copy">
    <div class="eyebrow-dark">Uso IA</div>
    <h2>{{ hero_title }}</h2>
    <p>{{ page_subtitle }}</p>
  </div>
  <div class="hero-aside">
    <div class="badge-live">{{ status.label }}</div>
    <div class="hero-aside-title">Estado IA</div>
    <p>{{ status.detail }}</p>
    <p class="subtle">La configuración técnica sigue reservada a super admin. Aquí sólo ves consumo, límites y solicitudes.</p>
  </div>
</section>

{{ feedback_html|raw }}
{{ error_html|raw }}

<section class="stats-grid">
  <article class="metric">
    <div class="metric-label">Consumo hoy</div>
    <div class="metric-value">{{ today.estimatedCostEur }}</div>
    <div class="metric-note">{{ today.totalTokens }} tokens procesados hoy.</div>
  </article>
  <article class="metric">
    <div class="metric-label">Consumo este mes</div>
    <div class="metric-value">{{ month.estimatedCostEur }}</div>
    <div class="metric-note">{{ month.totalTokens }} tokens procesados este mes.</div>
  </article>
  <article class="metric">
    <div class="metric-label">{{ daily_limit.label }}</div>
    <div class="metric-value">{{ daily_limit.value }}</div>
    <div class="metric-note">Usado: {{ daily_limit.used }} | Restante: {{ daily_limit.remaining }}</div>
  </article>
  <article class="metric">
    <div class="metric-label">{{ monthly_limit.label }}</div>
    <div class="metric-value">{{ monthly_limit.value }}</div>
    <div class="metric-note">Usado: {{ monthly_limit.used }} | Restante: {{ monthly_limit.remaining }}</div>
  </article>
</section>

<section class="cards-grid mb-4">
  <article class="usage-meter">
    <div class="usage-meter-header">
      <div class="usage-meter-title">{{ daily_limit.label }}</div>
      <span class="{{ daily_limit.class }}">{{ daily_limit.percent_label }}</span>
    </div>
    <div class="usage-meter-track" aria-hidden="true">
      <div class="usage-meter-fill{{ daily_limit.percent is not null and daily_limit.percent >= 100 ? ' is-warn' : '' }}" style="width: {{ daily_limit.percent is not null ? daily_limit.percent : 0 }}%"></div>
    </div>
    <div class="usage-meter-meta">
      <span><strong>Límite:</strong> {{ daily_limit.value }}</span>
      <span><strong>Usado:</strong> {{ daily_limit.used }}</span>
      <span><strong>Restante:</strong> {{ daily_limit.remaining }}</span>
    </div>
  </article>

  <article class="usage-meter">
    <div class="usage-meter-header">
      <div class="usage-meter-title">{{ monthly_limit.label }}</div>
      <span class="{{ monthly_limit.class }}">{{ monthly_limit.percent_label }}</span>
    </div>
    <div class="usage-meter-track" aria-hidden="true">
      <div class="usage-meter-fill{{ monthly_limit.percent is not null and monthly_limit.percent >= 100 ? ' is-warn' : '' }}" style="width: {{ monthly_limit.percent is not null ? monthly_limit.percent : 0 }}%"></div>
    </div>
    <div class="usage-meter-meta">
      <span><strong>Límite:</strong> {{ monthly_limit.value }}</span>
      <span><strong>Usado:</strong> {{ monthly_limit.used }}</span>
      <span><strong>Restante:</strong> {{ monthly_limit.remaining }}</span>
    </div>
  </article>
</section>

<section class="profile-grid">
  <article class="profile-card">
    <div class="profile-card-header">
      <h3>{{ period.label }}</h3>
      <span class="subtle">{{ period.current }}</span>
    </div>
    <div class="profile-card-body">
      <p>Reinicio diario estimado: <strong>{{ period.daily_reset }}</strong></p>
      <p>Reinicio mensual estimado: <strong>{{ period.monthly_reset }}</strong></p>
      <p class="subtle">Las cifras se calculan desde los eventos IA registrados para el tenant activo.</p>
    </div>
  </article>

  <article class="profile-card">
    <div class="profile-card-header">
      <h3>Solicitar ampliación</h3>
      <span class="subtle">Estado pendiente</span>
    </div>
    <div class="profile-card-body">
      <p>Envía una solicitud con importe y motivo. No modifica límites todavía.</p>
      <form method="post" action="{{ action_url }}" class="tenant-form">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
        <div class="form-grid">
          <div class="field">
            <label for="ai-usage-request-amount">Importe solicitado (€)</label>
            <input id="ai-usage-request-amount" name="requestedAmountEur" type="number" min="0.01" step="0.01" value="{{ values.requestedAmountEur }}" required>
          </div>
          <div class="field field-full">
            <label for="ai-usage-request-message">Motivo</label>
            <textarea id="ai-usage-request-message" name="message" rows="4" maxlength="2000" required>{{ values.message }}</textarea>
          </div>
        </div>
        <div class="form-actions">
          <button class="primary-action" type="submit">Enviar solicitud</button>
        </div>
      </form>
    </div>
  </article>
</section>

<section class="table-card">
  <div class="table-header">
    <div>
      <h3>Últimas solicitudes</h3>
      <p>Solicitudes pendientes o resueltas para este tenant.</p>
    </div>
  </div>

  <div class="table-responsive">
    <table class="request-table">
      <thead>
        <tr>
          <th scope="col">Fecha</th>
          <th scope="col">Importe</th>
          <th scope="col">Motivo</th>
          <th scope="col">Estado</th>
          <th scope="col">Solicitado por</th>
        </tr>
      </thead>
      <tbody>
        {% for request in recentRequests %}
          <tr>
            <td class="subtle">{{ request.createdAt }}</td>
            <td><strong>{{ request.amountEur }}</strong></td>
            <td class="message-cell">{{ request.message }}</td>
            <td><span class="request-status {{ request.status_class }}">{{ request.status }}</span></td>
            <td>{{ request.requestedBy }}</td>
          </tr>
        {% else %}
          <tr>
            <td colspan="5" class="empty-row">No hay solicitudes de ampliación todavía.</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</section>

<section class="table-card">
  <div class="table-header">
    <div>
      <h3>Eventos recientes</h3>
      <p>Últimas señales de uso IA registradas para este negocio.</p>
    </div>
  </div>

  <div class="table-responsive">
    <table class="request-table">
      <thead>
        <tr>
          <th scope="col">Fecha</th>
          <th scope="col">Feature</th>
          <th scope="col">Proveedor</th>
          <th scope="col">Modelo</th>
          <th scope="col">Tokens / coste</th>
          <th scope="col">Estado</th>
        </tr>
      </thead>
      <tbody>
        {% for event in recentEvents %}
          <tr>
            <td class="subtle">{{ event.createdAt }}</td>
            <td>{{ event.feature }}</td>
            <td>{{ event.provider }}</td>
            <td>
              <strong>{{ event.model }}</strong>
              <div class="subtle">Input {{ event.inputTokens }} | Output {{ event.outputTokens }} | Cached {{ event.cachedTokens }}</div>
            </td>
            <td>
              <strong>{{ event.totalTokens }}</strong>
              <div class="subtle">{{ event.estimatedCostEur }} | {{ event.latencyMs }}</div>
            </td>
            <td><span class="{{ event.status_class }}">{{ event.status }}</span></td>
          </tr>
        {% else %}
          <tr>
            <td colspan="6" class="empty-row">No hay eventos IA recientes para este negocio.</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</section>
