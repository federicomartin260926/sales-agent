APP_ENV=dev
APP_DEBUG=1
APP_SECRET=change-me-in-prod

POSTGRES_DB=sales_agent
POSTGRES_USER=sales_agent
POSTGRES_PASSWORD=secret

DATABASE_URL=postgresql://sales_agent:secret@sales-agent-db:5432/sales_agent?serverVersion=15&charset=utf8

API_PORT=8000
BACKEND_PORT=9000
NGINX_PORT=8080
API_HOST_PORT=8000
POSTGRES_HOST_PORT=5432

LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_RESPONSES_TIMEOUT_SECONDS=60
OPENAI_RESPONSES_MAX_ATTEMPTS=2
OPENAI_RESPONSES_RETRY_DELAY_SECONDS=0.5
OPENAI_CONVERSATION_STATE_ENABLED=true
OPENAI_CONVERSATION_STATE_TTL_HOURS=24
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
SA_DEFAULT_BUSINESS_TIMEZONE=Europe/Madrid
CONTACT_CONTEXT_CACHE_TTL_MINUTES=360
OLLAMA_BASE_URL=http://ollama-vpn-bridge:11434

RAG_API_URL=
PUBLIC_WHATSAPP_NUMBER=
MCP_TEST_AUTHORIZATION=

SALES_AGENT_BEARER_TOKEN=sales-agent-bearer-token
AUDIO_GATEWAY_BASE_URL=
AUDIO_GATEWAY_BEARER_TOKEN=
AUDIO_TIMEOUT_SECONDS=15
AUDIO_MAX_BYTES=26214400

JWT_PASSPHRASE=change-me
JWT_SECRET_KEY=/var/www/html/backend/var/jwt/private.pem
JWT_PUBLIC_KEY=/var/www/html/backend/var/jwt/public.pem
JWT_TTL=3600
